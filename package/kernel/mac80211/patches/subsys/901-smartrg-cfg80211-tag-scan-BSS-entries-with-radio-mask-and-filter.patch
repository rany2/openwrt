From: Chad Monroe <chad@monroe.io>
Date: Tue, 28 Oct 2025 16:14:12 -0700
Subject: [PATCH] cfg80211: tag scan BSS entries with radio mask and filter results

tag each BSS entry with the corresponding radio mask and use it to
filter relevant entries when dumping to userspace.

prevents returning scan entries for other bands in single wiphy mode.

Signed-off-by: Chad Monroe <chad@monroe.io>
---
 net/wireless/core.h    |    1 +
 net/wireless/nl80211.c |   13 +++++++++++++
 net/wireless/scan.c    |   18 ++++++++++++++++++
 3 files changed, 32 insertions(+)

--- a/net/wireless/core.h
+++ b/net/wireless/core.h
@@ -190,6 +190,7 @@ struct cfg80211_internal_bss {
 	unsigned long ts;
 	unsigned long refcount;
 	atomic_t hold;
+	u32 radio_mask;
 
 	/* time at the start of the reception of the first octet of the
 	 * timestamp field of the last beacon/probe received for this BSS.
--- a/net/wireless/nl80211.c
+++ b/net/wireless/nl80211.c
@@ -11652,6 +11652,7 @@ static int nl80211_dump_scan(struct sk_b
 	struct nlattr **attrbuf;
 	int start = cb->args[2], idx = 0;
 	bool dump_include_use_data;
+	u32 iface_mask, all_mask;
 	int err;
 
 	attrbuf = kcalloc(NUM_NL80211_ATTR, sizeof(*attrbuf), GFP_KERNEL);
@@ -11670,6 +11671,14 @@ static int nl80211_dump_scan(struct sk_b
 		attrbuf[NL80211_ATTR_BSS_DUMP_INCLUDE_USE_DATA];
 	kfree(attrbuf);
 
+	iface_mask = 0;
+	if (wdev->netdev)
+		iface_mask = rdev_get_radio_mask(rdev, wdev->netdev);
+	all_mask = rdev->wiphy.n_radio ?
+		BIT(rdev->wiphy.n_radio) - 1 : ~0U;
+	if (!iface_mask)
+		iface_mask = wdev->radio_mask ? wdev->radio_mask : all_mask;
+
 	spin_lock_bh(&rdev->bss_lock);
 
 	/*
@@ -11684,6 +11693,10 @@ static int nl80211_dump_scan(struct sk_b
 	cb->seq = rdev->bss_generation;
 
 	list_for_each_entry(scan, &rdev->bss_list, list) {
+		u32 bss_mask = scan->radio_mask ? scan->radio_mask : all_mask;
+
+		if (!(bss_mask & iface_mask))
+			continue;
 		if (++idx <= start)
 			continue;
 		if (!dump_include_use_data &&
--- a/net/wireless/scan.c
+++ b/net/wireless/scan.c
@@ -1952,6 +1952,7 @@ cfg80211_update_known_bss(struct cfg8021
 	if (signal_valid)
 		known->pub.signal = new->pub.signal;
 	known->pub.capability = new->pub.capability;
+	known->radio_mask = new->radio_mask;
 	known->parent_tsf = new->parent_tsf;
 	known->pub.chains = new->pub.chains;
 	memcpy(known->pub.chain_signal, new->pub.chain_signal,
@@ -2301,6 +2302,23 @@ cfg80211_inform_single_bss_data(struct w
 			NL80211_BSS_CANNOT_USE_6GHZ_PWR_MISMATCH;
 	}
 
+	if (wiphy->n_radio) {
+		struct cfg80211_chan_def chandef = {};
+		u32 mask = 0;
+		int i;
+
+		cfg80211_chandef_create(&chandef, channel, NL80211_CHAN_HT20);
+		for (i = 0; i < wiphy->n_radio; i++) {
+			if (cfg80211_radio_chandef_valid(&wiphy->radio[i],
+							 &chandef))
+				mask |= BIT(i);
+		}
+
+		tmp.radio_mask = mask ? mask : BIT(wiphy->n_radio) - 1;
+	} else {
+		tmp.radio_mask = ~0U;
+	}
+
 	memcpy(tmp.pub.bssid, data->bssid, ETH_ALEN);
 	tmp.pub.channel = channel;
 	if (data->bss_source != BSS_SOURCE_STA_PROFILE)
