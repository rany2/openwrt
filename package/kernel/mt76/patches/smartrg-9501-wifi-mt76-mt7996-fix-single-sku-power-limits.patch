+++ b/mt7996/vendor.h
@@ -17,7 +17,7 @@ enum mtk_vendor_attr_txpower_ctrl {
 	MTK_VENDOR_ATTR_TXPOWER_CTRL_LPI_PSD,
 	MTK_VENDOR_ATTR_TXPOWER_CTRL_SKU_IDX,
