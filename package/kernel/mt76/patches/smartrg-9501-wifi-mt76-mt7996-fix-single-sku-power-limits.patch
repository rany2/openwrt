From: Chad Monroe <chad@monroe.io>
Date: Tue, 17 Sep 2024 04:54:04 -0700
Subject: [PATCH] mt76: mt7996: fix single SKU power limits

* add mt7996 specific get_rate_power_limits() as the path power
  limit sizes are different from MT7915. there are better ways
  to solve this but not without significant modification to
  existing patches.
* add Canada to the list of PSD limited countries
* default sku_path_en to false and only enable it once a path
  power entry is found in the device tree
* re-apply single SKU limits after SER event

Signed-off-by: Chad Monroe <chad@monroe.io>
---
 eeprom.c             |  113 +++++++++++++++++++++++++++++++++++++++++
 mt76.h               |   14 +++++
 mt7996/init.c        |   12 ++--
 mt7996/main.c        |    6 ++
 mt7996/mcu.c         |   13 ++--
 mt7996/mcu.h         |   31 ++++++++++-
 mt7996/mtk_debugfs.c |    2 
 mt7996/vendor.c      |   36 ++-----------
 8 files changed, 183 insertions(+), 44 deletions(-)

--- a/mt7996/mcu.h
+++ b/mt7996/mcu.h
@@ -1118,9 +1118,34 @@ enum {
 	UNI_CMD_THERMAL_PROTECT_DUTY_CONFIG,
 };
 
-enum {
-	UNI_TXPOWER_POWER_LIMIT_TABLE_CTRL = 4,
-};
+struct tx_power_ctrl {
+	u8 _rsv[4];
+
+	__le16 tag;
+	__le16 len;
+
+	u8 power_ctrl_id;
+	union {
+		bool sku_enable;
+		bool ate_mode_enable;
+		bool percentage_ctrl_enable;
+		bool bf_backoff_enable;
+		u8 show_info_category;
+		u8 power_drop_level;
+	};
+	u8 band_idx;
+	u8 rsv[1];
+} __packed;
+
+ enum {
+	UNI_TXPOWER_SKU_POWER_LIMIT_CTRL = 0,
+	UNI_TXPOWER_PERCENTAGE_CTRL = 1,
+	UNI_TXPOWER_PERCENTAGE_DROP_CTRL = 2,
+	UNI_TXPOWER_BACKOFF_POWER_LIMIT_CTRL = 3,
+ 	UNI_TXPOWER_POWER_LIMIT_TABLE_CTRL = 4,
+	UNI_TXPOWER_ATE_MODE_CTRL = 6,
+	UNI_TXPOWER_SHOW_INFO = 7,
+ };
 
 enum {
 	UNI_CMD_ACCESS_REG_BASIC = 0x0,
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -6148,7 +6148,7 @@ mt7996_update_max_txpower_cur(struct mt7
 
 static bool mt7996_is_psd_country(char *country)
 {
-	char psd_country_list[][3] = {"US", "KR", "BR", "CL", "MY", ""};
+	char psd_country_list[][3] = {"US", "CA", "KR", "BR", "CL", "MY", ""};
 	int i;
 
 	if (strlen(country) != 2)
@@ -6201,7 +6201,13 @@ int mt7996_mcu_set_txpower_sku(struct mt
 
 	if (txpower_setting == INT_MIN || txpower_setting > 127)
 		txpower_setting = 127;
+
+	dev_dbg(dev->mt76.dev, "%s: txpower_setting=%d phy->txpower=%d chainmask=0x%x n_chains=%d path_delta=%d",
+		__func__, txpower_setting, phy->txpower, mphy->chainmask, hweight16(mphy->chainmask),
+		mt76_tx_power_path_delta(hweight16(mphy->chainmask)));
+
 	txpower_limit = mt7996_get_power_bound(phy, txpower_setting);
+	//txpower_limit += mt76_tx_power_path_delta(hweight16(mphy->chainmask));
 
 	if (phy->sku_limit_en) {
 		la = kzalloc(sizeof(*la), GFP_KERNEL);
@@ -6216,6 +6222,9 @@ int mt7996_mcu_set_txpower_sku(struct mt
 		return 0;
 	}
 
+	dev_dbg(dev->mt76.dev, "%s: txpower_limit=%d ofdm[0]=%d mcs[0][0]=%d",
+		__func__, txpower_limit, la->ofdm[0], la->mcs[0][0]);
+
 	skb = mt76_mcu_msg_alloc(&dev->mt76, NULL,
 				 sizeof(req) + MT7996_SKU_PATH_NUM);
 	if (!skb) {
@@ -6230,7 +6239,7 @@ int mt7996_mcu_set_txpower_sku(struct mt
 	 * driver doesn't need to do it
 	 */
 	if (phy->mt76->cap.has_6ghz && mphy->dev->lpi_psd &&
-	    !mt7996_is_psd_country(dev->mt76.alpha2)) {
+	    mt7996_is_psd_country(dev->mt76.alpha2)) {
 		switch (mphy->chandef.width) {
 		case NL80211_CHAN_WIDTH_20:
 			skb_put_data(skb, &la->eht[3], 8);
@@ -6365,6 +6374,9 @@ int mt7996_mcu_set_lpi_psd(struct mt7996
 		.psd_limit = enable ? mt7996_is_psd_country(dev->mt76.alpha2) : 0,
 	};
 
+	dev_info(dev->mt76.dev, "%s: enable = %d, psd_limit = %d",
+			__func__, req.lpi_enable, req.psd_limit);
+
 	return mt76_mcu_send_msg(&phy->dev->mt76, MCU_WM_UNI_CMD(BAND_CONFIG),
 				 &req, sizeof(req), false);
 }
--- a/mt7996/main.c
+++ b/mt7996/main.c
@@ -50,6 +50,19 @@ int mt7996_run(struct mt7996_phy *phy)
 	phy->sr_enable = true;
 	phy->enhanced_sr_enable = true;
 
+	/* needed to re-apply power tables after SER */
+	if (phy->mt76->chanctx) {
+		u8 delta;
+		int current_txpower;
+
+		delta = mt76_tx_power_path_delta(hweight16(phy->mt76->chainmask));
+		current_txpower = DIV_ROUND_UP(phy->mt76->txpower_cur + delta, 2);
+		ret = mt7996_mcu_set_txpower_sku(phy, current_txpower);
+	}
+
+	dev_info(dev->mt76.dev, "%s: band = %d, sku enable = %d, path enable = %d\n", __func__, phy->mt76->band_idx,
+		dev->dbg.sku_disable ? 0 : phy->sku_limit_en, dev->dbg.sku_disable ? 0 : phy->sku_path_en);
+
 	ret = mt7996_mcu_set_tx_power_ctrl(phy, UNI_TXPOWER_SKU_POWER_LIMIT_CTRL,
 						dev->dbg.sku_disable ? 0 : phy->sku_limit_en);
 
@@ -677,6 +690,8 @@ int mt7996_set_channel(struct mt76_phy *
 {
 	struct mt7996_phy *phy = mphy->priv;
 	int ret;
+	u8 delta;
+	int current_txpower;
 
 	if (mphy->offchannel)
 		mt7996_mac_update_beacons(phy);
@@ -695,7 +710,9 @@ int mt7996_set_channel(struct mt76_phy *
 	if (ret)
 		goto out;
 
-	ret = mt7996_mcu_set_txpower_sku(phy);
+	delta = mt76_tx_power_path_delta(hweight16(mphy->chainmask));
+	current_txpower = DIV_ROUND_UP(mphy->txpower_cur + delta, 2);
+	ret = mt7996_mcu_set_txpower_sku(phy, current_txpower);
 	if (ret)
 		goto out;
 
--- a/mt7996/vendor.c
+++ b/mt7996/vendor.c
@@ -40,7 +40,7 @@ txpower_ctrl_policy[NUM_MTK_VENDOR_ATTRS
 	[MTK_VENDOR_ATTR_TXPOWER_CTRL_LPI_PSD] = { .type = NLA_U8 },
 	[MTK_VENDOR_ATTR_TXPOWER_CTRL_SKU_IDX] = { .type = NLA_U8 },
 	[MTK_VENDOR_ATTR_TXPOWER_CTRL_LPI_BCN_ENHANCE] = { .type = NLA_U8 },
-	[MTK_VENDOR_ATTR_TXPOWER_CTRL_LINK_ID] = { .type = NLA_U8 },
+	[MTK_VENDOR_ATTR_TXPOWER_CTRL_RADIO_IDX] = { .type = NLA_U8 },
 };
 
 static const struct nla_policy
@@ -106,6 +106,9 @@ static int mt7996_vendor_mu_ctrl(struct
 			return -EINVAL;
 		phy = dev->radio_phy[radio_idx];
 
+		dev_info(dev->mt76.dev, "%s: radio_idx=%u band=%u",
+				__func__, radio_idx, phy->mt76->band_idx);
+
 		val32 |= FIELD_PREP(RATE_CFG_MODE, RATE_PARAM_AUTO_MU) |
 			 FIELD_PREP(RATE_CFG_VAL, val8) |
 			 FIELD_PREP(RATE_CFG_BAND_IDX, phy->mt76->band_idx);
@@ -191,6 +194,9 @@ static int mt7996_vendor_edcca_ctrl(stru
 
 	phy = dev->radio_phy[radio_idx];
 
+	dev_info(dev->mt76.dev, "%s: radio_idx=%u band=%u",
+			__func__, radio_idx, phy->mt76->band_idx);
+
 	switch (edcca_mode) {
 	case EDCCA_CTRL_SET_EN:
 		if (!tb[MTK_VENDOR_ATTR_EDCCA_CTRL_PRI20_VAL])
@@ -309,6 +315,10 @@ static int mt7996_vendor_pp_ctrl(struct
 
 	if (tb[MTK_VENDOR_ATTR_PP_MODE]) {
 		val8 = nla_get_u8(tb[MTK_VENDOR_ATTR_PP_MODE]);
+
+		dev_info(dev->mt76.dev, "%s: band_idx=%u band=%u pp_en=%u",
+				__func__, band_idx, phy->mt76->band_idx, val8);
+
 		switch (val8) {
 		case PP_DISABLE:
 		case PP_FW_MODE:
@@ -335,18 +345,14 @@ static int mt7996_vendor_txpower_ctrl(st
 				      int data_len)
 {
 #define FR_RATE_IDX_OFDM_6M 0x004b
-	struct mt7996_dev *dev;
+	struct ieee80211_hw *hw = wiphy_to_ieee80211_hw(wiphy);
+	struct mt7996_dev *dev = mt7996_hw_dev(hw);
 	struct mt7996_phy *phy;
 	struct mt76_phy *mphy;
-	struct ieee80211_vif *vif = wdev_to_ieee80211_vif(wdev);
-	struct mt7996_vif *mvif = (struct mt7996_vif *)vif->drv_priv;
-	struct mt7996_vif_link *mconf;
 	struct nlattr *tb[NUM_MTK_VENDOR_ATTRS_TXPOWER_CTRL];
-	struct mt76_power_limits la = {};
