-	MTK_VENDOR_ATTR_TXPOWER_CTRL_LINK_ID,
+	MTK_VENDOR_ATTR_TXPOWER_CTRL_RADIO_IDX,
 
 	/* keep last */
 	NUM_MTK_VENDOR_ATTRS_TXPOWER_CTRL,
--- a/mt7996/init.c
+++ b/mt7996/init.c
@@ -370,7 +370,7 @@ static void __mt7996_init_txpower(struct
 		return;
 
 	phy->sku_limit_en = true;
-	phy->sku_path_en = true;
+	phy->sku_path_en = false;
 	np = mt76_find_power_limits_node(phy->mt76);
 	for (i = 0; i < sband->n_channels; i++) {
 		struct ieee80211_channel *chan = &sband->channels[i];
@@ -380,8 +380,10 @@ static void __mt7996_init_txpower(struct
 		target_power = mt76_get_rate_power_limits(phy->mt76, chan,
 							  limits,
