 		mphy->sku_idx = nla_get_u8(tb[MTK_VENDOR_ATTR_TXPOWER_CTRL_SKU_IDX]);
 
 		if (mt76_find_power_limits_node(mphy) == NULL)
@@ -396,12 +400,17 @@ static int mt7996_vendor_txpower_ctrl(st
 			mt7996_init_txpower(phy);
 		new_power_limit = chan->max_power;
 
+		dev_dbg(mphy->dev->dev, "%s: band=%u set sku_idx=%u",
+				__func__, phy->mt76->band_idx, mphy->sku_idx);
+
 		phy->sku_limit_en = true;
 		phy->sku_path_en = true;
 		mt76_get_rate_power_limits(mphy, chan, la, 127);
-		if (!la_path.ofdm[0])
+		if (!la->path.ofdm[0])
 			phy->sku_path_en = false;
 
+		kfree(la);
+
 		dev = phy->dev;
 		err = mt7996_mcu_set_tx_power_ctrl(phy, UNI_TXPOWER_SKU_POWER_LIMIT_CTRL,
 						   dev->dbg.sku_disable ? 0 : phy->sku_limit_en);
@@ -419,11 +428,15 @@ static int mt7996_vendor_txpower_ctrl(st
 		mphy->dev->lpi_bcn_enhance = val;
 		idx = MT7996_BEACON_RATES_TBL + 2 * phy->mt76->band_idx;
 
