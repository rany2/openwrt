@@ -2408,6 +2419,14 @@ int mt7996_mtk_init_debugfs(struct mt799
 
 	debugfs_create_u8("sku_disable", 0600, dir, &dev->dbg.sku_disable);
 
+	for (i = 0; i < hw->wiphy->n_radio; i++) {
