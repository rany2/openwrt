 	mt76_sta_ps_transition(&dev->mt76, wcid, !!p->ps_bit);
 }
 
+static u16
+mt7915_mcu_noisefloor_calculate(u16 *noisefloor_antenna, u8 antenna_offset, u8 nss)
+{
+	u8 antenna_idx;
+	u16 noisefloor = 0;
+
+	if (!nss)
+		return 0;
+
+	for (antenna_idx = antenna_offset; antenna_idx < antenna_offset + nss; antenna_idx++)
+		noisefloor += noisefloor_antenna[antenna_idx];
+
+
+	return noisefloor / nss;
+}
+
+static u16
+mt7915_mcu_noisefloor_ipi_calculate(u32 *ipi_histogram)
+{
+	u32 nf_power[] = {92, 89, 86, 83, 80, 75, 70, 65, 60, 55, 52};
+	u32 ipi_histogram_samples_total = 0;
+	u32 ipi_histogram_samples;
+	u32 ipi = 0;
+	u8 i;
+
+	for (i = 0; i < MT7915_NF_IPI_HISTOGRAM_SIZE; i++) {
+		ipi_histogram_samples = le32_to_cpu(ipi_histogram[i]);
+		ipi_histogram_samples_total += ipi_histogram_samples;
+		ipi += nf_power[i] * ipi_histogram_samples;
+	}
+
+	return ipi_histogram_samples_total ? ipi / ipi_histogram_samples_total : 0;
+}
+
+static void
+mt7915_mcu_noisefloor_update_phy(struct mt7915_phy *phy, u16 *noisefloor_antenna,
+				 int antenna_band_offset)
+{
+	phy->noise = mt7915_mcu_noisefloor_calculate(noisefloor_antenna, antenna_band_offset,
+						     hweight8(phy->mt76->chainmask));
+	phy->mt76->chan_state->noise = -phy->noise;
+}
+
+static void
+mt7915_mcu_noisefloor_notify(struct mt7915_dev *dev, struct sk_buff *skb)
+{
+	struct mt7915_mcu_noisefloor_notify *n;
+	struct mt7915_phy *ext_phy = mt7915_ext_phy(dev);
+	int band_offset = is_mt7915(&dev->mt76) ? MT7915_NF_BAND1_OFFSET : MT7916_NF_BAND1_OFFSET;
+	u16 noisefloor[MT7915_NF_ANTENNA_COUNT_MAX] = {0};
+	u8 antenna;
+	u32 ip;
+
+	n = (struct mt7915_mcu_noisefloor_notify *)skb->data;
+
+	/* Calculate noisefloor for each antenna */
+	if (n->mode == MT7915_NOISEFLOOR_IDLE_POWER) {
+		for (antenna = 0; antenna < MT7915_NF_ANTENNA_COUNT_IP; antenna++) {
+			ip = FIELD_GET(MT7915_NF_IDLE_POWER_MASK,
+				       le32_to_cpu(n->average_power[antenna]));
+			noisefloor[antenna] = 128 - ip;
+		}
+	} else if (n->mode == MT7915_NOISEFLOOR_IDLE_POWER_INDICATOR) {
+		for (antenna = 0; antenna < MT7915_NF_ANTENNA_COUNT_IPI; antenna++)
+			noisefloor[antenna] = mt7915_mcu_noisefloor_ipi_calculate(n->average_ipi_histogram[antenna]);
+	} else {
+		return;
+	}
+
+	/* Update calculated noisefloor */
+	mt7915_mcu_noisefloor_update_phy(&dev->phy, noisefloor, 0);
+	if (ext_phy)
+		mt7915_mcu_noisefloor_update_phy(ext_phy, noisefloor, band_offset);
+}
+
 static void
 mt7915_mcu_rx_ext_event(struct mt7915_dev *dev, struct sk_buff *skb)
 {
@@ -442,6 +517,9 @@ mt7915_mcu_rx_ext_event(struct mt7915_de
 	case MCU_EXT_EVENT_PS_SYNC:
 		mt7915_mcu_rx_ps_sync(dev, skb);
 		break;
+	case MCU_EXT_CMD_ENABLE_NOISEFLOOR:
+		mt7915_mcu_noisefloor_notify(dev, skb);
+		break;
 	default:
 		break;
 	}
@@ -472,6 +550,7 @@ void mt7915_mcu_rx_event(struct mt7915_d
 	     rxd->ext_eid == MCU_EXT_EVENT_FW_LOG_2_HOST ||
 	     rxd->ext_eid == MCU_EXT_EVENT_ASSERT_DUMP ||
 	     rxd->ext_eid == MCU_EXT_EVENT_PS_SYNC ||
+	     rxd->ext_eid == MCU_EXT_EVENT_NOISEFLOOR ||
 	     rxd->ext_eid == MCU_EXT_EVENT_BCC_NOTIFY ||
 	     !rxd->seq) &&
 	     !(rxd->eid == MCU_CMD_EXT_CID &&
@@ -3610,6 +3689,25 @@ int mt7915_mcu_set_test_param(struct mt7
 				 sizeof(req), false);
 }
 
+int mt7915_mcu_set_noisefloor(struct mt7915_phy *phy, bool enable, u8 timeout, u8 count)
+{
+	struct mt7915_dev *dev = phy->dev;
+	struct {
+		u8 enable;
+		u8 timeout;
+		u8 count;
+		u8 event_count;
+	} __packed req = {
+		.enable = enable,
+		.timeout = timeout,
+		.count = count,
+		.event_count = 0,
+	};
+
+	return mt76_mcu_send_msg(&dev->mt76, MCU_EXT_CMD(ENABLE_NOISEFLOOR), &req,
+				 sizeof(req), false);
+}
