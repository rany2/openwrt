From: Chad Monroe <chad@monroe.io>
Date: Wed, 25 Mar 2026 21:01:17 -0700
Subject: [PATCH] wifi: mt76: guard airtime counters against overflow

Clamp per-STA and channel MIB airtime deltas to elapsed monotonic
time between polls -- airtime physically cannot exceed it. Handle
u32 counter wrap and trigger WTBL counter clears before BIT(30) to
prevent wrap ambiguity.

Fix mt76_sta_stats tx/rx_airtime from u64 scalars to u32 per-AC
arrays to match how the mt7915 MCU handler indexes them.

Signed-off-by: Chad Monroe <chad@monroe.io>
---
 mt76.h           |   22 ++++++++++++++++-
 mt7915/mcu.c     |   56 ++++++++++++++++++++++++++++++++++++---------
 mt7915/mt7915.h  |    1 
 mt7996/debugfs.c |    8 ++++--
 mt7996/main.c    |    5 ----
 mt7996/mcu.c     |    6 ++--
 6 files changed, 75 insertions(+), 23 deletions(-)

--- a/mt76.h
+++ b/mt76.h
@@ -403,7 +403,7 @@ struct mt76_sta_stats {
 	u32 tx_mpdus;
 	u32 tx_retries;
 	u32 tx_failed;
-	u64 tx_airtime;
+	u32 tx_airtime[IEEE80211_NUM_ACS];
 	/* WED RX */
 	u64 rx_bytes;
 	u64 rx_bytes_per_ac[IEEE80211_NUM_ACS];
@@ -412,7 +412,7 @@ struct mt76_sta_stats {
 	u32 rx_fcs_err;
 	u32 rx_errors;
 	u32 rx_drops;
-	u64 rx_airtime;
+	u32 rx_airtime[IEEE80211_NUM_ACS];
 	u64 last_rx_bytes;
 };
 
@@ -1073,6 +1073,7 @@ struct mt76_dev {
 
 	struct list_head sta_poll_list;
 	spinlock_t sta_poll_lock;
+	unsigned long airtime_last_poll;
 
 	u32 rev;
 
@@ -1531,6 +1532,28 @@ mt76_ac_to_tid(u8 ac)
 	return ac_to_tid[ac];
 }
 
+static inline u32
+mt76_airtime_delta(u32 cur, u32 prev, u32 max_us)
+{
+	u32 diff = cur >= prev ? cur - prev : cur;
+
+	return diff <= max_us ? diff : 0;
+}
+
+static inline u32
+mt76_airtime_clamp(u32 val, u32 max_us)
+{
+	return val <= max_us ? val : 0;
+}
+
+static inline u64
+mt76_chan_mib_delta(u64 cur, u64 prev, u32 max_us)
+{
+	u64 diff = cur - prev;
+
+	return diff <= max_us ? diff : 0;
+}
+
 static inline struct ieee80211_txq *
 mtxq_to_txq(struct mt76_txq *mtxq)
 {
--- a/mt7915/mcu.c
+++ b/mt7915/mcu.c
@@ -551,15 +551,24 @@ static void
 mt7915_mcu_rx_all_sta_info_event(struct mt7915_dev *dev, struct sk_buff *skb)
 {
 	struct mt7915_mcu_all_sta_info_event *res;
+	u32 elapsed_us = 0;
 	u16 i;
 
 	res = (struct mt7915_mcu_all_sta_info_event *)skb->data;
+
+	if (res->tag == MCU_PHY_PER_STA_TXRX_AIR_TIME) {
+		unsigned long now = jiffies;
+
+		elapsed_us = jiffies_to_usecs(now - dev->mt76.airtime_last_poll);
+		dev->mt76.airtime_last_poll = now;
+	}
 	for (i = 0; i < le16_to_cpu(res->sta_num); i++) {
 		u8 ac;
 		u16 wlan_idx;
 		struct mt76_wcid *wcid;
 		struct ieee80211_sta *sta;
-		u32 tx_airtime, rx_airtime;
+		u32 diff_tx, diff_rx;
+		bool clear = false;
 
 		switch (res->tag) {
 		case MCU_PHY_PER_STA_TXRX_AIR_TIME:
@@ -572,15 +581,29 @@ mt7915_mcu_rx_all_sta_info_event(struct
 
 			for (ac = IEEE80211_AC_VO; ac < IEEE80211_NUM_ACS; ++ac) {
 				u8 lmac_ac = mt76_connac_lmac_mapping(ac);
+				u32 cur_tx = le32_to_cpu(res->airtime[i].tx[lmac_ac]);
+				u32 cur_rx = le32_to_cpu(res->airtime[i].rx[lmac_ac]);
 
-				tx_airtime = le32_to_cpu(res->airtime[i].tx[lmac_ac]);
-				rx_airtime = le32_to_cpu(res->airtime[i].rx[lmac_ac]);
+				diff_tx = mt76_airtime_delta(cur_tx,
+							     wcid->stats.tx_airtime[ac],
+							     elapsed_us);
+				diff_rx = mt76_airtime_delta(cur_rx,
+							     wcid->stats.rx_airtime[ac],
+							     elapsed_us);
+
+				wcid->stats.tx_airtime[ac] = cur_tx;
+				wcid->stats.rx_airtime[ac] = cur_rx;
+
+				if ((cur_tx | cur_rx) & BIT(30))
+					clear = true;
 
-				wcid->stats.tx_airtime += tx_airtime;
-				wcid->stats.rx_airtime += rx_airtime;
 				ieee80211_sta_register_airtime(sta, mt76_ac_to_tid(ac),
-							       tx_airtime, rx_airtime);
+							       diff_tx, diff_rx);
 			}
+
+			if (clear)
+				mt7915_mac_wtbl_update(dev, wcid->idx,
+						       MT_WTBL_UPDATE_ADM_COUNT_CLEAR);
 			break;
 		default:
 			break;
@@ -3386,6 +3409,8 @@ int mt7915_mcu_get_chan_mib_info(struct
 	struct sk_buff *skb;
 	static const u32 *offs;
 	int i, ret, len, offs_cc;
+	unsigned long now;
+	u32 elapsed_us;
 	u64 cc_tx;
 
 	/* strict order */
@@ -3436,11 +3461,18 @@ int mt7915_mcu_get_chan_mib_info(struct
 	if (chan_switch)
 		goto out;
 
-	state->cc_tx += cc_tx - state_ts->cc_tx;
-	state->cc_bss_rx += __res_u64(2) - state_ts->cc_bss_rx;
-	state->cc_rx += __res_u64(2) + __res_u64(3) - state_ts->cc_rx;
-	state->cc_busy += __res_u64(0) + cc_tx + __res_u64(2) + __res_u64(3) -
-			  state_ts->cc_busy;
+	now = jiffies;
+	elapsed_us = jiffies_to_usecs(now - phy->chan_mib_last_poll);
+	phy->chan_mib_last_poll = now;
+
+	state->cc_tx += mt76_chan_mib_delta(cc_tx, state_ts->cc_tx, elapsed_us);
+	state->cc_bss_rx += mt76_chan_mib_delta(__res_u64(2), state_ts->cc_bss_rx,
+						elapsed_us);
+	state->cc_rx += mt76_chan_mib_delta(__res_u64(2) + __res_u64(3),
+					    state_ts->cc_rx, elapsed_us);
+	state->cc_busy += mt76_chan_mib_delta(__res_u64(0) + cc_tx +
+					      __res_u64(2) + __res_u64(3),
+					      state_ts->cc_busy, elapsed_us);
 
 out:
 	state_ts->cc_tx = cc_tx;
--- a/mt7915/mt7915.h
+++ b/mt7915/mt7915.h
@@ -292,6 +292,7 @@ struct mt7915_phy {
 
 	struct mt76_mib_stats mib;
 	struct mt76_channel_state state_ts;
+	unsigned long chan_mib_last_poll;
 	struct delayed_work ipi_work;
 
 	bool sku_limit_en:1;
--- a/mt7996/debugfs.c
+++ b/mt7996/debugfs.c
@@ -1502,7 +1502,9 @@ mt7996_link_sta_info_show(struct seq_fil
 		   stats->tx_mpdus ? stats->tx_failed * 1000 / stats->tx_mpdus / 10 : 0,
 		   stats->tx_mpdus ? stats->tx_failed * 1000 / stats->tx_mpdus % 10 : 0);
 	seq_printf(file, "\t\tMPDU Retries: %u\n", stats->tx_retries);
-	seq_printf(file, "\t\tAirtime: %llu (unit: 1.024 us)\n", stats->tx_airtime);
+	seq_printf(file, "\t\tAirtime (unit: 1.024 us):\n");
+	for (ac = IEEE80211_AC_VO; ac < IEEE80211_NUM_ACS; ++ac)
+		seq_printf(file, "\t\t\t%s: %u\n", ac_to_str(ac), stats->tx_airtime[ac]);
 	seq_printf(file, "\t\tNumber of non-AQL packets: %u (Max: %u)\n",
 		   atomic_read(&wcid->non_aql_packets), MT_MAX_NON_AQL_PKT);
 	seq_printf(file, "\tRX:\n");
@@ -1513,7 +1515,9 @@ mt7996_link_sta_info_show(struct seq_fil
 	seq_printf(file, "\t\tMPDU FCS Errors: %u (PER: %u.%u%%)\n", stats->rx_fcs_err,
 		   stats->rx_mpdus ? stats->rx_fcs_err * 1000 / stats->rx_mpdus / 10 : 0,
 		   stats->rx_mpdus ? stats->rx_fcs_err * 1000 / stats->rx_mpdus % 10 : 0);
-	seq_printf(file, "\t\tAirtime: %llu (unit: 1.024 us)\n", stats->rx_airtime);
+	seq_printf(file, "\t\tAirtime (unit: 1.024 us):\n");
+	for (ac = IEEE80211_AC_VO; ac < IEEE80211_NUM_ACS; ++ac)
+		seq_printf(file, "\t\t\t%s: %u\n", ac_to_str(ac), stats->rx_airtime[ac]);
 
 	seq_printf(file, "\tWCID flags:\n");
 	for (flag = 0; flag < NUM_MT76_WCID_FLAGS; flag++) {
--- a/mt7996/main.c
+++ b/mt7996/main.c
@@ -2089,11 +2089,6 @@ static void mt7996_link_sta_statistics(s
 	link_sinfo->fcs_err_count = stats->rx_fcs_err;
 	link_sinfo->filled |= BIT_ULL(NL80211_STA_INFO_FCS_ERROR_COUNT);
 
-	link_sinfo->tx_duration = stats->tx_airtime;
-	link_sinfo->filled |= BIT_ULL(NL80211_STA_INFO_TX_DURATION);
-
-	link_sinfo->rx_duration = stats->rx_airtime;
-	link_sinfo->filled |= BIT_ULL(NL80211_STA_INFO_RX_DURATION);
 out:
 	mutex_unlock(&dev->mt76.mutex);
 }
--- a/mt7996/mcu.c
+++ b/mt7996/mcu.c
@@ -880,10 +880,10 @@ mt7996_mcu_rx_all_sta_info_event(struct
 				tx_airtime = le32_to_cpu(res->airtime[i].tx[lmac_ac]);
 				rx_airtime = le32_to_cpu(res->airtime[i].rx[lmac_ac]);
 
-				wcid->stats.tx_airtime += tx_airtime;
-				wcid->stats.rx_airtime += rx_airtime;
+				wcid->stats.tx_airtime[ac] += tx_airtime;
+				wcid->stats.rx_airtime[ac] += rx_airtime;
 				ieee80211_sta_register_airtime(sta, mt76_ac_to_tid(ac),
-				                               tx_airtime, rx_airtime);
+							       tx_airtime, rx_airtime);
 			}
 			break;
 		case UNI_ALL_STA_RX_MPDU_COUNT:
