From d5499fffe2d2f9ed09f329dfdbb146144b4781ca Mon Sep 17 00:00:00 2001
From: David Bauer <mail@david-bauer.net>
Date: Fri, 6 Feb 2026 08:56:51 +0100
Subject: [PATCH] wifi: mt76: add HW flag for storing PS frames

---
 mt7915/init.c | 1 +
 1 file changed, 1 insertion(+)

diff --git a/mt7915/init.c b/mt7915/init.c
index 2da6ea91..c27fea9f 100644
--- a/mt7915/init.c
+++ b/mt7915/init.c
@@ -412,6 +412,7 @@ mt7915_init_wiphy(struct mt7915_phy *phy)
 	ieee80211_hw_set(hw, SUPPORTS_MULTI_BSSID);
 	ieee80211_hw_set(hw, WANT_MONITOR_VIF);
 	ieee80211_hw_set(hw, SUPPORTS_TX_FRAG);
+	ieee80211_hw_set(hw, STORES_PS_FRAMES);
 
 	hw->max_tx_fragments = 4;
 
-- 
2.51.0

