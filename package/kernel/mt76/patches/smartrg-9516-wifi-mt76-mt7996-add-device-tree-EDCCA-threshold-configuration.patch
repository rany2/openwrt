From: Chad Monroe <chad@monroe.io>
Date: Wed, 07 Jan 2026 11:25:54 -0800
Subject: [PATCH] mt76: mt7996: add device tree EDCCA threshold configuration

Allow per-band EDCCA thresholds to be specified in device tree power-limits
nodes using edcca-threshold-bw{20,40,80,160} properties. Thresholds are
applied on regulatory domain change and preserve firmware defaults for any
unspecified bandwidths.

Signed-off-by: Chad Monroe <chad@monroe.io>
---
 eeprom.c        |   54 ++++++++++++++++++++++++++++++++++++++++++++++
 mt76.h          |    8 ++++++
 mt7996/init.c   |   50 ++++++++++++++++++++++++++++++++++++++++++
 mt7996/mac.c    |    4 ++-
 mt7996/main.c   |    3 ++
 mt7996/mt7996.h |    1
 6 files changed, 119 insertions(+), 1 deletion(-)

--- a/eeprom.c
+++ b/eeprom.c
@@ -581,6 +581,60 @@ s8 mt76_get_rate_power_limits(struct mt7
 }
 EXPORT_SYMBOL_GPL(mt76_get_rate_power_limits);
 
+int mt76_get_edcca_limits(struct mt76_phy *phy,
+			  struct ieee80211_channel *chan,
+			  struct mt76_edcca_limits *dest)
+{
+	static const char * const bw_names[] = {
+		"edcca-threshold-bw20",
+		"edcca-threshold-bw40",
+		"edcca-threshold-bw80",
+		"edcca-threshold-bw160",
+	};
+	struct device_node *np;
+	char name[16];
+	char band;
+	int i;
+
+	memset(dest, 0, sizeof(*dest));
+
+	if (!IS_ENABLED(CONFIG_OF))
+		return 0;
+
+	np = mt76_find_power_limits_node(phy);
+	if (!np)
+		return 0;
+
+	switch (chan->band) {
+	case NL80211_BAND_2GHZ:
+		band = '2';
+		break;
+	case NL80211_BAND_5GHZ:
+		band = '5';
+		break;
+	case NL80211_BAND_6GHZ:
+		band = '6';
+		break;
+	default:
+		return 0;
+	}
+
+	snprintf(name, sizeof(name), "txpower-%cg", band);
+	np = of_get_child_by_name(np, name);
+	if (!np)
+		return 0;
+
+	for (i = 0; i < ARRAY_SIZE(bw_names); i++) {
+		if (!of_property_read_u8(np, bw_names[i], &dest->threshold[i]))
+			dest->valid_mask |= BIT(i);
+	}
+
+	of_node_put(np);
+
+	return 0;
+}
+EXPORT_SYMBOL_GPL(mt76_get_edcca_limits);
+
 int
 mt76_eeprom_init(struct mt76_dev *dev, int len)
 {
--- a/mt76.h
+++ b/mt76.h
@@ -1254,6 +1254,11 @@ struct mt76_power_limits {
 	} path;
 };
 
+struct mt76_edcca_limits {
+	u8 threshold[4];
+	u8 valid_mask;
+};
+
 struct mt76_ethtool_worker_info {
 	u64 *data;
 	int idx;
@@ -2099,6 +2104,9 @@ s8 mt76_get_rate_power_limits(struct mt7
 			      struct ieee80211_channel *chan,
 			      struct mt76_power_limits *dest,
 			      s8 target_power);
+int mt76_get_edcca_limits(struct mt76_phy *phy,
+			  struct ieee80211_channel *chan,
+			  struct mt76_edcca_limits *dest);
 
 static inline bool mt76_queue_is_rx(struct mt76_dev *dev, struct mt76_queue *q)
 {
--- a/mt7996/init.c
+++ b/mt7996/init.c
@@ -411,6 +411,55 @@ void mt7996_init_txpower(struct mt7996_p
 		__mt7996_init_txpower(phy, &phy->mt76->sband_6g.sband);
 }
 
+void mt7996_apply_edcca_limits(struct mt7996_phy *phy)
+{
+	struct mt76_edcca_limits limits;
+	struct ieee80211_channel *chan;
+	u8 current_thresh[4];
+	int ret, i;
+
+	if (!phy->mt76->chandef.chan) {
+		dev_info(phy->dev->mt76.dev, "EDCCA: no channel defined\n");
+		return;
+	}
+
+	chan = phy->mt76->chandef.chan;
+
+	ret = mt76_get_edcca_limits(phy->mt76, chan, &limits);
+	if (ret || !limits.valid_mask)
+		return;
+
+	dev_dbg(phy->dev->mt76.dev,
+		"EDCCA: band=%d valid_mask=0x%x threshold=[%02x,%02x,%02x,%02x]\n",
+		chan->band, limits.valid_mask,
+		limits.threshold[0], limits.threshold[1],
+		limits.threshold[2], limits.threshold[3]);
+
+	ret = mt7996_mcu_edcca_enable(phy, true);
+	if (ret) {
+		dev_warn(phy->dev->mt76.dev,
+			 "failed to enable EDCCA: %d\n", ret);
+		return;
+	}
+
+	ret = mt7996_mcu_edcca_threshold_ctrl(phy, current_thresh, false);
+	if (ret) {
+		dev_warn(phy->dev->mt76.dev,
+			 "failed to read EDCCA threshold: %d\n", ret);
+		return;
+	}
+
+	for (i = 0; i < 4; i++) {
+		if (limits.valid_mask & BIT(i))
+			current_thresh[i] = limits.threshold[i];
+	}
+
+	ret = mt7996_mcu_edcca_threshold_ctrl(phy, current_thresh, true);
+	if (ret)
+		dev_warn(phy->dev->mt76.dev,
+			 "failed to set EDCCA threshold: %d\n", ret);
+}
+
 static void
 mt7996_regd_notifier(struct wiphy *wiphy,
 		     struct regulatory_request *request)
@@ -427,6 +476,7 @@ mt7996_regd_notifier(struct wiphy *wiphy
 			mt7996_mcu_rdd_background_enable(phy, NULL);
 
 		mt7996_init_txpower(phy);
+		mt7996_apply_edcca_limits(phy);
 		phy->mt76->dfs_state = MT_DFS_STATE_UNKNOWN;
 		mt7996_dfs_init_radar_detector(phy);
 	}
--- a/mt7996/mac.c
+++ b/mt7996/mac.c
@@ -2197,8 +2197,10 @@ mt7996_mac_restart(struct mt7996_dev *de
 		goto out;
 
 	mt7996_mac_init(dev);
-	mt7996_for_each_phy(dev, phy)
+	mt7996_for_each_phy(dev, phy) {
 		mt7996_init_txpower(phy);
+		mt7996_apply_edcca_limits(phy);
+	}
 	ret = mt7996_txbf_init(dev);
 	if (ret)
 		goto out;
--- a/mt7996/main.c
+++ b/mt7996/main.c
@@ -716,6 +716,9 @@ int mt7996_set_channel(struct mt76_phy *
 	if (ret)
 		goto out;
 
+	if (!mphy->offchannel && !test_bit(MT76_SCANNING, &mphy->state))
+		mt7996_apply_edcca_limits(phy);
+
 	ret = mt7996_dfs_init_radar_detector(phy);
 	mt7996_mac_cca_stats_reset(phy);
 
--- a/mt7996/mt7996.h
+++ b/mt7996/mt7996.h
@@ -834,6 +834,7 @@ void mt7996_dma_start(struct mt7996_dev
 int mt7996_init_tx_queues(struct mt7996_phy *phy, int idx,
 			  int n_desc, int ring_base, struct mtk_wed_device *wed);
 void mt7996_init_txpower(struct mt7996_phy *phy);
+void mt7996_apply_edcca_limits(struct mt7996_phy *phy);
 int mt7996_txbf_init(struct mt7996_dev *dev);
 void mt7996_reset(struct mt7996_dev *dev);
 int mt7996_run(struct mt7996_phy *phy);
